{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error Contract",
  "type": "object",
  "properties": {
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "request_id": { "type": ["string", "null"] }
      },
      "required": ["code", "message"],
      "additionalProperties": false
    }
  },
  "required": ["error"],
  "additionalProperties": false
}