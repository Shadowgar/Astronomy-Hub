{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Response Envelope",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "data": {
      "type": ["object", "array", "null"],
      "additionalProperties": true
    },
    "meta": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "required": ["status"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ok" } }
      },
      "then": {
        "properties": {
          "error": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "error" } }
      },
      "then": {
        "required": ["error"]
      }
    }
  ]
}