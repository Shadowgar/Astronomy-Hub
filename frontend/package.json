{
  "name": "astronomy-hub-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite --port 4173 --strictPort",
    "build": "vite build",
    "test": "vitest run",
    "test:guard": "vitest run tests/skyEngineImportBoundary.test.js",
    "test:e2e": "playwright test",
    "test:e2e:docker": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173 PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "preview": "vite preview --port 4173 --strictPort",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "cesium": "^1.139.1",
    "esri-leaflet": "^3.0.19",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "three": "^0.180.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.2.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "dompurify": "^3.4.0"
  },
