    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "three": "^0.180.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.0.0",
