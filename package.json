{
  "name": "astronomy-hub",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "spectorjs": "^0.9.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev -- --host 0.0.0.0",
    "dev:backend": "python3 -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:wsl": "bash scripts/dev-wsl-stack.sh up",
    "dev:wsl:down": "bash scripts/dev-wsl-stack.sh down",
    "dev:wsl:restart": "bash scripts/dev-wsl-stack.sh restart",
    "dev:wsl:status": "bash scripts/dev-wsl-stack.sh status",
    "dev:wsl:logs": "bash scripts/dev-wsl-stack.sh logs",
    "dev:stellarium": "bash scripts/dev-stellarium-local.sh up",
    "dev:stellarium:down": "bash scripts/dev-stellarium-local.sh down",
    "dev:stellarium:restart": "bash scripts/dev-stellarium-local.sh restart",
    "dev:stellarium:status": "bash scripts/dev-stellarium-local.sh status",
    "dev:stellarium:logs": "bash scripts/dev-stellarium-local.sh logs",
    "prepare:stellarium-runtime": "bash scripts/sync-stellarium-runtime.sh",
    "build:stellarium": "bash scripts/prepare-stellarium-reference.sh && cd vendor/stellarium-web-engine/apps/web-frontend && ORAS_RUNTIME_PUBLIC_PATH=/oras-sky-engine/ NODE_OPTIONS=--openssl-legacy-provider npm run build && cd /home/rocco/Astronomy-Hub && npm run prepare:stellarium-runtime",
    "scan:runtime-external-deps": ".venv/bin/python scripts/skydata/scan_runtime_external_dependencies.py",
    "scan:runtime-external-deps:fail": ".venv/bin/python scripts/skydata/scan_runtime_external_dependencies.py --fail-on-runtime-forbidden",
    "serve:stellarium": "npm run dev:stellarium",
    "dev:parity": "npm run dev:wsl && npm run dev:stellarium",
    "validate:sky-fast": "cd frontend && npm run typecheck && npm run test -- tests/sky-engine-runtime-frame-projection.test.js tests/sky-engine-stars-runtime.test.js tests/test_scene_query_state.test.js tests/test_painter_backend_port.test.js && npm run build",
    "profile:sky-local": "cd frontend && npm run profile:sky-engine-runtime",
    "docker:dev-backend": "bash scripts/docker-dev-backend.sh",
    "docker:stellarium:up": "bash scripts/prepare-stellarium-reference.sh && docker compose up -d --build stellarium-reference",
    "docker:stellarium:down": "docker compose rm -sf stellarium-reference",
    "docker:reference-stack:up": "bash scripts/prepare-stellarium-reference.sh && docker compose up -d --build backend frontend stellarium-reference",
    "snyk:test": "snyk test --all-projects --exclude=.venv --command=python3",
    "push:github": "bash scripts/push-to-github.sh",
    "fix:git-cred": "bash scripts/fix-git-credential-wsl-once.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shadowgar/Astronomy-Hub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Shadowgar/Astronomy-Hub/issues"
  },
  "homepage": "https://github.com/Shadowgar/Astronomy-Hub#readme"
}
