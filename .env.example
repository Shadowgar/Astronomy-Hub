## Phase 2.5 — Environment example (backend-focused)
# Copy this to `.env` and edit values for local development.

# Backend bind port (server.py reads PORT env var; default 8000)
PORT=8000

# Logging level used by backend/logging_config.py (INFO|DEBUG|WARN|ERROR)
LOG_LEVEL=INFO

# Test/dev-only flags (used by backend tests)
# Set to 'conditions' to simulate normalizer failure in tests: SIMULATE_NORMALIZER_FAIL=conditions
SIMULATE_NORMALIZER_FAIL=
