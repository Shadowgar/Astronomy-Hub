# Environment example for Astronomy-Hub
# Copy this file to `.env` and adjust values for your environment.

# Minimal canonical variables for Workstream 2.5B (Docker & env foundation)
# - `BACKEND_PORT`: port where backend binds
# - `FRONTEND_PORT`: port used for frontend preview/dev
# - `API_URL`: canonical base URL the frontend should use to reach the backend
# - `NODE_ENV`: frontend/node environment (development|production)

# Backend bind port
BACKEND_PORT=8000

# Frontend preview / static server port
FRONTEND_PORT=4173

# Canonical API URL (frontend proxy and local clients should use this)
API_URL=http://127.0.0.1:8000

# Node environment
NODE_ENV=development

# Optional: backend logging level (kept for convenience)
LOG_LEVEL=INFO

# Optional: feature/test flags (used by some backend tests)
SIMULATE_NORMALIZER_FAIL=false
