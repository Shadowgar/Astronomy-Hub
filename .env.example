# Environment example for Astronomy-Hub
# Copy this file to `.env` and adjust values for your environment.

# Backend service port (backend/server.py reads `PORT`)
PORT=8000

# Logging level for backend (backend/logging_config.py reads `LOG_LEVEL`)
LOG_LEVEL=INFO

# Feature/test flags (used by some tests)
SIMULATE_NORMALIZER_FAIL=false

# Frontend preview port (matches `frontend/package.json` preview script)
VITE_PREVIEW_PORT=4173

# Canonical backend URL for local dev (frontend proxy expects http://127.0.0.1:8000)
BACKEND_URL=http://127.0.0.1:8000
## Phase 2.5 — Environment example (backend-focused)
# Copy this to `.env` and edit values for local development.

# Backend bind port (server.py reads PORT env var; default 8000)
PORT=8000

# Logging level used by backend/logging_config.py (INFO|DEBUG|WARN|ERROR)
LOG_LEVEL=INFO

# Test/dev-only flags (used by backend tests)
# Set to 'conditions' to simulate normalizer failure in tests: SIMULATE_NORMALIZER_FAIL=conditions
SIMULATE_NORMALIZER_FAIL=
